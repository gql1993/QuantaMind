{
  "name": "quantamind-desktop",
  "version": "1.0.0",
  "description": "QuantaMind 桌面客户端 - 可安装的量子科研 AI 中台",
  "main": "main.js",
  "author": "QuantaMind",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.quantamind.desktop",
    "productName": "QuantaMind",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "ui/**"],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
