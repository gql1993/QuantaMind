# Copy this file to .quantamind.local.env and fill in your values.
# Existing system environment variables still take precedence.

QUANTAMIND_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/replace-with-your-webhook
QUANTAMIND_FEISHU_KEYWORD=QuantaMind情报

# Needed only if you want images embedded in Feishu cards.
QUANTAMIND_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
QUANTAMIND_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
